# =========================================================================
# Бренд и страна
# =========================================================================
# Три рабочих набора. Скопируй один в .env.local.
#
#  ┌──────────┬───────────┬──────────────────────────┬──────────────┬──────────┐
#  │ APP_NAME │ COUNTRY   │ BASE_API_URL             │ Логотип      │ Валюта   │
#  ├──────────┼───────────┼──────────────────────────┼──────────────┼──────────┤
#  │ kassir   │ kg        │ https://gateway.kassir.kg│ logosPage/kg │ сом      │
#  │ showgo   │ uz        │ https://api.showgo.uz    │ logosPage/uz │ сум      │
#  │ showgotj │ tj        │ https://api.showgo.tj    │ logosPage/tj │ сомони   │
#  └──────────┴───────────┴──────────────────────────┴──────────────┴──────────┘
#
# `NEXT_PUBLIC_IP_API_URL` — в продакшене может отличаться (Python backend
# vs Cloudflare). На локалке/dev обычно совпадает с BASE_API_URL.

# kassir.kg
NEXT_PUBLIC_APP_NAME=kassir
NEXT_PUBLIC_COUNTRY_CODE=kg
NEXT_PUBLIC_BASE_API_URL=https://gateway.kassir.kg
NEXT_PUBLIC_IP_API_URL=https://gateway.kassir.kg

# showgo.uz
# NEXT_PUBLIC_APP_NAME=showgo
# NEXT_PUBLIC_COUNTRY_CODE=uz
# NEXT_PUBLIC_BASE_API_URL=https://api.showgo.uz
# NEXT_PUBLIC_IP_API_URL=https://api.showgo.uz

# showgo.tj
# NEXT_PUBLIC_APP_NAME=showgotj
# NEXT_PUBLIC_COUNTRY_CODE=tj
# NEXT_PUBLIC_BASE_API_URL=https://api.showgo.tj
# NEXT_PUBLIC_IP_API_URL=https://api.showgo.tj

# =========================================================================
# Окружение
# =========================================================================
# development | staging | production
NEXT_PUBLIC_APP_ENV=development

# Публичный URL фронта (нужен для sitemap, metadataBase, OG).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
