# Public backend base URL
NEXT_PUBLIC_BASE_API_URL=https://api.showgo.tj

# Backend used for IP geolocation / region detection
NEXT_PUBLIC_IP_API_URL=https://api.showgo.tj

# ISO 3166-1 alpha-2 country code (lowercase)
NEXT_PUBLIC_COUNTRY_CODE=tj

# Public app name (used in metadata, manifest, headers, etc.)
NEXT_PUBLIC_APP_NAME=showgotj

# Runtime environment: development | staging | production
NEXT_PUBLIC_APP_ENV=development

# Public site URL (used by sitemap / metadataBase)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
